{
  "name": "bedest",
  "version": "1.1.0",
  "description": "B.E.D. Stack Boilerplate",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "bedest-core": "^1.0.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.6.2",
    "pg": "^8.21.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@elysiajs/eden": "^1.4.9",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development bun --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir ./dist",
    "start": "NODE_ENV=production bun dist/index.js",
    "test": "bun test",
    "lint": "eslint 'src/**/*.{ts,js}' --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "bun run src/scripts/database/DatabaseReset.ts && bun run src/scripts/storage/StorageReset.ts",
    "db:seed": "bun run src/scripts/seed/seed.ts",
    "db:setup": "rm -rf drizzle && bun run db:reset && bun run db:generate && bun run db:migrate",
    "dev:setup": "bun run db:setup && bun run db:seed"
  }
}
